# ────────────────────────────────────────────────────────────────────────
# CleanUp — environment variables (development defaults)
# Copy to .env and adjust for production.
# ────────────────────────────────────────────────────────────────────────

# Mongo
MONGO_URI=mongodb://mongo:27017
MONGO_INITDB_ROOT_USERNAME=cleanup
MONGO_INITDB_ROOT_PASSWORD=cleanup

# JWT (RS256). Generate with:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# AES-256 key for at-rest secret config (32 random bytes, base64):
#   openssl rand -base64 32
CONFIG_ENC_KEY=replace-me-with-32-random-bytes-base64

# Seeded admin (first-run)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123

# Inter-service shared secret (HMAC for service-to-service auth)
INTERNAL_API_SECRET=dev-internal-secret

# Nginx
NGINX_HOST=localhost
NGINX_PORT=80

# Frontend
REACT_APP_API_BASE=/api

# CORS (comma-separated origins; * in dev)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# Logging
LOG_LEVEL=info
